    {
      "parameters": {
        "jsCode": "const allSlots = [\n  \"09:30\",\n  \"10:10\",\n  \"10:50\",\n  \"11:30\",\n  \"12:10\",\n  \"12:50\",\n  \"13:30\",\n  \"14:10\",\n  \"14:50\",\n  \"15:30\",\n  \"16:10\",\n  \"16:50\",\n  \"17:30\",\n  \"18:10\",\n  \"18:50\",\n  \"19:30\",\n  \"20:10\",\n  \"20:50\",\n  \"21:30\",\n  \"22:10\",\n  \"22:50\"\n];\n\n// Saati 24h HH:mm formatına çevir\nfunction normalizeTime(value) {\n  if (!value) return \"\";\n\n  const str = String(value).trim().toUpperCase();\n\n  // 12 saatlik format: 10:30 AM / 9:05 PM\n  const ampmMatch = str.match(/^(\\d{1,2}):(\\d{2})\\s*(AM|PM)$/);\n  if (ampmMatch) {\n    let hour = parseInt(ampmMatch[1], 10);\n    const minute = ampmMatch[2];\n    const meridiem = ampmMatch[3];\n\n    if (meridiem === \"PM\" && hour !== 12) hour += 12;\n    if (meridiem === \"AM\" && hour === 12) hour = 0;\n\n    return `${String(hour).padStart(2, \"0\")}:${minute}`;\n  }\n\n  // 24 saatlik format: 9:30 / 14:10 / 09:30\n  const hmMatch = str.match(/^(\\d{1,2}):(\\d{2})$/);\n  if (hmMatch) {\n    const hour = String(parseInt(hmMatch[1], 10)).padStart(2, \"0\");\n    const minute = hmMatch[2];\n    return `${hour}:${minute}`;\n  }\n\n  return str;\n}\n\n// DB'den dolu saatleri al ve normalize et\nconst booked = $input.all()\n  .map(item => normalizeTime(item.json.appointment_time))\n  .filter(Boolean);\n\n// Tekilleştir\nconst bookedSet = [...new Set(booked)];\n\n// Slot listesi oluştur\nconst slots = allSlots.map(time => ({\n  time,\n  available: !bookedSet.includes(time),\n}));\n\nreturn [\n  {\n    json: {\n      success: true,\n      booked: bookedSet,\n      slots\n    }\n  }\n];"
      },
