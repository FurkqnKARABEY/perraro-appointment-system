    {
      "parameters": {
        "jsCode": "// FILTER: 24 saat içindeki randevular\n// Sabit timezone: America/Los_Angeles (Santa Ana, CA)\nconst TIMEZONE = 'America/Los_Angeles';\nconst results = [];\n\nconst nowUtc = $now.toUTC();\nconst nowMillis = nowUtc.toMillis();\nconst currentTimeUtcFormatted = nowUtc.toFormat('yyyy-MM-dd HH:mm:ss');\n\nconsole.log('Current Time UTC: ' + currentTimeUtcFormatted);\nconsole.log('Checking appointments...\\n');\n\nfor (let i = 0; i < $input.all().length; i++) {\n  const item = $input.all()[i].json;\n\n  const apptDate = item.appointment_date;\n  const apptTime = item.appointment_time;\n\n  if (!apptDate || !apptTime) {\n    console.log('Skipping: appointment_date or appointment_time missing');\n    continue;\n  }\n\n  // appointment_date: YYYY-MM-DD\n  const dateParts = apptDate.split('-');\n  const year  = parseInt(dateParts[0], 10);\n  const month = parseInt(dateParts[1], 10);\n  const day   = parseInt(dateParts[2], 10);\n\n  // appointment_time: 12:45 PM veya 09:30 (24h)\n  let hour, minute;\n  const ampmMatch = apptTime.match(/(\\d+):(\\d+)\\s*(AM|PM)/i);\n  const hmMatch   = apptTime.match(/^(\\d{1,2}):(\\d{2})$/);\n\n  if (ampmMatch) {\n    hour   = parseInt(ampmMatch[1], 10);\n    minute = parseInt(ampmMatch[2], 10);\n    const meridiem = ampmMatch[3].toUpperCase();\n    if (meridiem === 'PM' && hour !== 12) hour += 12;\n    if (meridiem === 'AM' && hour === 12)  hour = 0;\n  } else if (hmMatch) {\n    hour   = parseInt(hmMatch[1], 10);\n    minute = parseInt(hmMatch[2], 10);\n  } else {\n    console.log('Invalid time format: ' + apptTime);\n    continue;\n  }\n\n  const apptDateTime = $now.setZone(TIMEZONE).set({ year, month, day, hour, minute, second: 0, millisecond: 0 });\n  const apptMillis   = apptDateTime.toUTC().toMillis();\n\n  const diffMs      = apptMillis - nowMillis;\n  const diffHours   = diffMs / (1000 * 60 * 60);\n  const diffMinutes = Math.floor(diffMs / (1000 * 60));\n  const absDiffHours   = Math.abs(diffHours);\n  const absDiffMinutes = Math.abs(diffMinutes);\n\n  const status = diffHours > 0 ? 'FUTURE' : diffHours < 0 ? 'PAST' : 'NOW';\n  console.log(`Appointment: ${apptDate} ${apptTime} | ${status} | Hours: ${diffHours.toFixed(2)}`);\n\n  if (absDiffHours < 24) {\n    console.log('✅ INCLUDED\\n');\n    results.push({\n      json: {\n        ...item,\n        hoursUntil:      Math.floor(diffHours),\n        minutesUntil:    diffMinutes,\n        hoursFromNow:    Math.floor(absDiffHours),\n        minutesFromNow:  absDiffMinutes,\n        isPast:          diffHours < 0,\n        isFuture:        diffHours > 0,\n        isNow:           diffHours === 0,\n        currentTimeUTC:  currentTimeUtcFormatted,\n      },\n    });\n  } else {\n    console.log('❌ EXCLUDED - More than 24 hours away\\n');\n  }\n}\n\nresults.sort((a, b) => a.json.minutesFromNow - b.json.minutesFromNow);\nconsole.log('Total results: ' + results.length);\nreturn results;"
      },
